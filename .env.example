# Скопируй в .env (локально) или впиши те же переменные в Railway -> Variables.
# Файл .env в .gitignore, наружу не уходит. Реальные значения сюда не пиши.

# --- обязательные ---

# Токен бота из @BotFather
TELEGRAM_BOT_TOKEN=токен_от_botfather

# Ключ Claude из console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=ключ_anthropic

# Твой Telegram id (@userinfobot). Защита кошелька: бот ответит только тебе.
# Несколько через запятую: 123456789,987654321
ALLOWED_USER_IDS=твой_telegram_id

# --- ПАМЯТЬ (главное отличие этого бота) ---

# Строка подключения к Postgres. Без неё бот работает, но забывает всё при
# перезапуске. С ней — помнит историю и держит связь между разговорами.
# Два простых способа:
#   Railway: New -> Database -> Add PostgreSQL. Переменная DATABASE_URL
#     подставится автоматически, вписывать ничего не нужно.
#   Supabase (бесплатно): Project -> Settings -> Database -> Connection string
#     (URI). Вид: postgresql://postgres:ПАРОЛЬ@ХОСТ:5432/postgres
DATABASE_URL=

# --- личность коуча ---

# Личность целиком (приватно, чтобы личное не попало в публичный репозиторий).
# Если пусто — берётся файл personality.md.
COACH_PROMPT=

# --- необязательные ---

# claude-sonnet-4-6 (по умолчанию) · claude-opus-4-8 (глубже) ·
# claude-haiku-4-5-20251001 (дешевле)
MODEL=claude-sonnet-4-6
MAX_TOKENS=1024
# сколько последних реплик подгружать в каждый ответ
HISTORY=16
